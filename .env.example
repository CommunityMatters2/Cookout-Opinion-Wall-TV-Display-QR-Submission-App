NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUBMIT_URL=
# Optional: a second vercel.app domain added to this same project that should
# show the TV wall (/display) at its root, e.g. cm2-cookout-tv.vercel.app
TV_DOMAIN=

# Shared password for the hidden moderator view at /mod. Pick something you
# can read off a phone easily; rotate it after the event.
MOD_PASSWORD=

# Optional: protects app/api/cron/golden-opinion — set the same value in
# Vercel's Cron settings if your plan supports custom cron headers.
CRON_SECRET=
